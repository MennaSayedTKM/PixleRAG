# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# The ngrok URL printed by the Colab notebook at the end of each session.
# This changes every time the notebook restarts — update it here (or in the
# Streamlit sidebar) each time.
EMBED_API_URL=https://xxxx-xx-xx-xxx-xxx.ngrok-free.app

# Your OpenAI API key — used for answer synthesis (gpt-4o).
# Get it from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Jina AI API key — required only when reranker=jina-reranker-v2-base-multimodal in config.yaml.
# Get it from https://jina.ai  (free tier available)
JINA_API_KEY=jina_...
